pkgbase = gpu-screen-recorder
	pkgdesc = A shadowplay-like screen recorder for Linux. The fastest screen recorder for Linux
	pkgver = r1287.57caf13
	pkgrel = 1
	url = https://git.dec05eba.com/gpu-screen-recorder
	install = gpu-screen-recorder.install
	arch = x86_64
	license = GPL-3.0-only
	makedepends = meson
	makedepends = vulkan-headers
	depends = ffmpeg
	depends = libglvnd
	depends = libxcomposite
	depends = libxrandr
	depends = libxfixes
	depends = libxdamage
	depends = libx11
	depends = libpulse
	depends = libva
	depends = libdrm
	depends = libcap
	depends = wayland
	depends = libpipewire
	depends = dbus
	depends = libjpeg-turbo
	optdepends = nvidia-utils: Required to record your screen on NVIDIA
	optdepends = libxnvctrl: Required when using the -oc option to overclock the NVIDIA GPU to workaround NVIDIA p2 state bug
	optdepends = mesa: Required to record your screen on AMD/Intel
	optdepends = libva-mesa-driver: Required to record your screen on AMD
	optdepends = libva-intel-driver: Required to record your screen on Intel G45 and HD Graphics family
	optdepends = intel-media-driver: Required to record your screen on Intel Broadwell or later iGPUs or Intel Arc
	optdepends = linux-firmware-intel: Required to record your screen on Intel Skylake or later iGPUs
