From 8d49375eff603615323a6144e287ffd6a8429b1b Mon Sep 17 00:00:00 2001
From: Intel <intel@local>
Date: Tue, 3 Mar 2026 15:30:43 -0800
Subject: [PATCH] icvs: set rgbcamera_pwrup_host=0 for Panther Lake

On Panther Lake, sensor power goes through USBIO GPIO which is managed
by CVS firmware, not the host. With the default rgbcamera_pwrup_host=1,
the sensor never powers up and I2C reads time out with -ETIMEDOUT.

Setting this to 0 tells CVS firmware to handle sensor power sequencing
via USBIO GPIO, which is the correct path on PTL.
---
 drivers/misc/icvs/intel_cvs_update.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/misc/icvs/intel_cvs_update.c b/drivers/misc/icvs/intel_cvs_update.c
index 5f069aa..5dc4c85 100644
--- a/drivers/misc/icvs/intel_cvs_update.c
+++ b/drivers/misc/icvs/intel_cvs_update.c
@@ -54,7 +54,7 @@ int cvs_write_i2c(u16 cmd, u8 *data, u32 len)
 		host_identifiers.field.vision_sensing = 0;
 		host_identifiers.field.device_power_setting = 0;
 		host_identifiers.field.privacy_led_host = 0;
-		host_identifiers.field.rgbcamera_pwrup_host = 1;
+		host_identifiers.field.rgbcamera_pwrup_host = 0;

 		memcpy(&out_buff[2], &host_identifiers.value,
 			   cv_host_identifier_size);
--
2.53.0
