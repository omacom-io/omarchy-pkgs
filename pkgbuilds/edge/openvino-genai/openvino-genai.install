post_install() {
  ldconfig
  echo ">>> OpenVINO GenAI runtime installed."
  echo ">>> Libraries are available system-wide via ldconfig."
  echo ">>> Shell environment (cmake, pkg-config) available via: source /etc/profile.d/openvino-genai.sh"
  echo ">>> (New login shells pick it up automatically.)"
}

post_upgrade() {
  post_install
}

post_remove() {
  ldconfig
}
