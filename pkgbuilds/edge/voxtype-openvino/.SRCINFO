pkgbase = voxtype-openvino
	pkgdesc = Push-to-talk voice-to-text for Linux (OpenVINO/NPU build)
	pkgver = 0.6.4
	pkgrel = 1
	url = https://voxtype.io
	install = voxtype-openvino.install
	arch = x86_64
	license = MIT
	makedepends = git
	makedepends = cargo
	makedepends = rust
	makedepends = cmake
	depends = alsa-lib
	depends = curl
	depends = gcc-libs
	depends = glibc
	depends = intel-npu-driver
	depends = openvino-genai
	optdepends = wtype: keyboard simulation for Wayland (recommended, best CJK support)
	optdepends = dotool: keyboard simulation with layout support (KDE/GNOME compatible)
	optdepends = ydotool: keyboard simulation fallback (X11/TTY support)
	optdepends = wl-clipboard: clipboard support
	optdepends = libnotify: desktop notifications
	optdepends = pipewire: audio server (recommended)
	optdepends = pipewire-alsa: ALSA compatibility for PipeWire (required if using PipeWire)
	optdepends = pulseaudio: audio server (alternative to PipeWire)
	optdepends = ollama: local AI summarization for meeting mode
	provides = voxtype
	conflicts = voxtype
	conflicts = voxtype-bin
	backup = etc/voxtype/config.toml
	source = voxtype::git+https://github.com/jacob-vincent-mink/voxtype.git#branch=feature/intel-npu
	source = openvino-rs::git+https://github.com/jacob-vincent-mink/openvino-rs.git#branch=feature/genai
	source = config-0.6.4.toml::https://raw.githubusercontent.com/peteonrails/voxtype/v0.6.4/config/default.toml
	source = voxtype-0.6.4.service::https://raw.githubusercontent.com/peteonrails/voxtype/v0.6.4/packaging/systemd/voxtype.service
	source = voxtype-0.6.4.bash::https://raw.githubusercontent.com/peteonrails/voxtype/v0.6.4/packaging/completions/voxtype.bash
	source = voxtype-0.6.4.zsh::https://raw.githubusercontent.com/peteonrails/voxtype/v0.6.4/packaging/completions/voxtype.zsh
	source = voxtype-0.6.4.fish::https://raw.githubusercontent.com/peteonrails/voxtype/v0.6.4/packaging/completions/voxtype.fish
	source = LICENSE-0.6.4::https://raw.githubusercontent.com/peteonrails/voxtype/v0.6.4/LICENSE
	source = README-0.6.4.md::https://raw.githubusercontent.com/peteonrails/voxtype/v0.6.4/README.md
