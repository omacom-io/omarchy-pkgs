diff -ruN a/PKGBUILD b/PKGBUILD
--- a/PKGBUILD	2026-06-12 01:10:32.081893787 -0400
+++ b/PKGBUILD	2026-06-12 01:10:32.083938150 -0400
@@ -1,25 +1,30 @@
-# Maintainer:
-# Contributor: Timothy Gu <timothygu99@gmail.com>
-# Contributor: Ivan Shapovalov <intelfx@intelfx.name>
-
-## links
-# https://fprint.freedesktop.org
-# https://gitlab.freedesktop.org/libfprint/libfprint
-
-## basic info
-_pkgname="libfprint"
-pkgname="$_pkgname-git"
-pkgver=1.94.7.r29.g3f70bde
-pkgrel=1
-pkgdesc="Library for fingerprint readers"
-url="https://gitlab.freedesktop.org/libfprint/libfprint"
-license=('LGPL-2.1-or-later')
