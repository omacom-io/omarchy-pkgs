# Maintainer: Alexandre Bouvier <contact@amb.tf>
# Contributor: Oliver Jaksch <arch-aur@com-in.de>
_pkgname=libretro-database
# Intentionally pinned to the latest successful repository build.
_commit=9aec58983a73ba4370ba6fd7c1b7d915ec56dda6
pkgname=$_pkgname-git
pkgver=1.22.1.r200.g9aec589
pkgrel=1
epoch=1
pkgdesc="RetroArch's cheatcode files, content data files, etc."
arch=('any')
url="https://github.com/libretro/libretro-database"
license=('CC-BY-SA-4.0')
groups=('libretro')
makedepends=('git')
optdepends=('retroarch')
provides=("$_pkgname=$pkgver")
conflicts=("$_pkgname")
options=('!strip')
source=("$_pkgname::git+$url.git#commit=$_commit")
b2sums=('SKIP')

pkgver() {
	cd $_pkgname
	git describe --long --tags --abbrev=7 | sed 's/^v//;s/[^-]*-g/r&/;s/-/./g'
}

package() {
	cd $_pkgname
	# shellcheck disable=SC2154
	make DESTDIR="$pkgdir" install
}
