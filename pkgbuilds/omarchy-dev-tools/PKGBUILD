# Maintainer: Ryan Hughes <ryan@omarchy.org>
pkgname='omarchy-dev-tools'
pkgver=4.0.0.alpha
pkgrel=1
pkgdesc='Developer commands for working on Omarchy'
arch=('any')
url='https://github.com/basecamp/omarchy'
license=('MIT')
provides=('omarchy-dev-tools')

depends=(
  'bash'
  'omarchy'
)

# Source: GitHub tag tarball by default; set OMARCHY_SRC=/path/to/checkout to
# build from a local source tree instead (mirrors omarchy-zsh/omarchy-fish DX).
# Until v4.0.0.alpha is tagged on basecamp/omarchy, sha256sums=('SKIP').
#
# TODO(chunk-4): `omarchy-dev-link`, `omarchy-dev-unlink`, `omarchy-dev-status`,
# and `omarchy-dev-pkg-test` are added in Chunk 4 (Phase DX). This skeleton
# only ships the currently-existing `omarchy-dev-*` commands.
if [[ -n "${OMARCHY_SRC:-}" ]]; then
  source=()
  sha256sums=()
else
  source=("omarchy-${pkgver}.tar.gz::https://github.com/basecamp/omarchy/archive/refs/tags/v${pkgver}.tar.gz")
  sha256sums=('SKIP')
fi

prepare() {
  if [[ -n "${OMARCHY_SRC:-}" ]]; then
    rm -rf "$srcdir/omarchy-${pkgver}"
    mkdir -p "$srcdir/omarchy-${pkgver}"
    cp -a "${OMARCHY_SRC}/." "$srcdir/omarchy-${pkgver}/"
  fi
}

package() {
  cd "$srcdir/omarchy-${pkgver}"

  install -d "$pkgdir/usr/bin"
  for bin in bin/omarchy-dev-*; do
    [[ -f $bin ]] || continue
    install -Dm755 "$bin" "$pkgdir/usr/bin/$(basename "$bin")"
  done
}
