# Maintainer: Ryan Hughes <ryan@omarchy.org>
pkgname='omarchy-installer'
pkgver=4.0.0.alpha
pkgrel=5
pkgdesc='Omarchy installation scripts and helpers'
arch=('any')
url='https://github.com/basecamp/omarchy'
license=('MIT')
provides=('omarchy-installer')

# Intentionally minimal: omarchy-installer is the install runner, not a
# transitive pull for the full system. install.sh pacman -Syu's omarchy itself
# during the online install; the ISO pacstraps omarchy + omarchy-installer
# together so /etc/skel is populated before the user is created.
depends=(
  'bash'
  'gum'
  'jq'
  'git'
)

# Source: GitHub tag tarball by default; set OMARCHY_SRC=/path/to/checkout to
# build from a local source tree instead (mirrors omarchy-zsh/omarchy-fish DX).
# Until v4.0.0.alpha is tagged on basecamp/omarchy, sha256sums=('SKIP').
if [[ -n "${OMARCHY_SRC:-}" ]]; then
  source=()
  sha256sums=()
else
  source=("omarchy-${pkgver}.tar.gz::https://github.com/basecamp/omarchy/archive/refs/tags/v${pkgver}.tar.gz")
  sha256sums=('SKIP')
fi

prepare() {
  if [[ -n "${OMARCHY_SRC:-}" ]]; then
    rm -rf "$srcdir/omarchy-${pkgver}"
    mkdir -p "$srcdir/omarchy-${pkgver}"
    cp -a "${OMARCHY_SRC}/." "$srcdir/omarchy-${pkgver}/"
  fi
}

package() {
  cd "$srcdir/omarchy-${pkgver}"

  install -Dm755 install.sh  "$pkgdir/usr/share/omarchy/install.sh"
  install -Dm755 finalize.sh "$pkgdir/usr/share/omarchy/finalize.sh"
  install -Dm755 bin/omarchy-install "$pkgdir/usr/bin/omarchy-install"

  install -d "$pkgdir/usr/share/omarchy/install"
  cp -a install/. "$pkgdir/usr/share/omarchy/install/"

  # The ISO orchestrator writes /etc/default/limine before omarchy-limine is
  # installed on the target so limine-mkinitcpio-hook sees the final cmdline on
  # its first run. Ship just the templates as installer assets for the live ISO
  # without pulling omarchy-limine's target-system hooks into the live image.
  install -Dm644 default/limine/default.conf \
    "$pkgdir/usr/share/omarchy/install/assets/limine/default.conf"
  install -Dm644 default/limine/limine.conf \
    "$pkgdir/usr/share/omarchy/install/assets/limine/limine.conf"
}
