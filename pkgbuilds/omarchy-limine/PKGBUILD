# Maintainer: Ryan Hughes <ryan@omarchy.org>
pkgname='omarchy-limine'
pkgver=4.0.0.alpha
pkgrel=1
pkgdesc='Limine bootloader configuration, mkinitcpio hooks, and snapper template for Omarchy'
arch=('any')
url='https://github.com/basecamp/omarchy'
license=('MIT')
provides=('omarchy-limine')

# NOTE(chunk-7): `/etc/default/limine` is intentionally NOT owned by this
# package. It is generated at install time from the boot cmdline by
# `configure-limine.sh` (lands in Chunk 7). We ship a template under
# `/usr/share/omarchy/limine/` for the generator to read.

depends=(
  'limine'
  'limine-mkinitcpio-hook'
  'limine-snapper-sync'
  'snapper'
)

backup=(
  'etc/mkinitcpio.conf.d/omarchy_hooks.conf'
  'etc/limine-entry-tool.d/omarchy-uki.conf'
)

# Source: GitHub tag tarball by default; set OMARCHY_SRC=/path/to/checkout to
# build from a local source tree instead (mirrors omarchy-zsh/omarchy-fish DX).
# Until v4.0.0.alpha is tagged on basecamp/omarchy, sha256sums=('SKIP').
if [[ -n "${OMARCHY_SRC:-}" ]]; then
  source=(
    'omarchy_hooks.conf'
    'omarchy-uki.conf'
    'thunderbolt_module.conf'
  )
  sha256sums=(
    'SKIP'
    'SKIP'
    'SKIP'
  )
else
  source=(
    "omarchy-${pkgver}.tar.gz::https://github.com/basecamp/omarchy/archive/refs/tags/v${pkgver}.tar.gz"
    'omarchy_hooks.conf'
    'omarchy-uki.conf'
    'thunderbolt_module.conf'
  )
  sha256sums=(
    'SKIP'
    'SKIP'
    'SKIP'
    'SKIP'
  )
fi

prepare() {
  if [[ -n "${OMARCHY_SRC:-}" ]]; then
    rm -rf "$srcdir/omarchy-${pkgver}"
    mkdir -p "$srcdir/omarchy-${pkgver}"
    cp -a "${OMARCHY_SRC}/." "$srcdir/omarchy-${pkgver}/"
  fi
}

package() {
  cd "$srcdir/omarchy-${pkgver}"

  # mkinitcpio hooks for limine/snapper integration. Content must match
  # the line currently produced by install/login/limine-snapper.sh in the
  # installer (verified 2026-05-20). If the installer's hook line changes,
  # this file must be updated in lockstep.
  install -Dm644 "$srcdir/omarchy_hooks.conf" \
    "$pkgdir/etc/mkinitcpio.conf.d/omarchy_hooks.conf"

  # Thunderbolt module drop-in, sibling to omarchy_hooks.conf (also written
  # by the current installer).
  install -Dm644 "$srcdir/thunderbolt_module.conf" \
    "$pkgdir/etc/mkinitcpio.conf.d/thunderbolt_module.conf"

  # Limine entry-tool default drop-in (UKI by default; configure-limine.sh
  # may override on BIOS).
  install -Dm644 "$srcdir/omarchy-uki.conf" \
    "$pkgdir/etc/limine-entry-tool.d/omarchy-uki.conf"

  # Limine theme/preset and /etc/default/limine template. Both ship under
  # /usr/share/omarchy/default/limine/ to match the installer's source-tree
  # layout (install/login/limine-snapper.sh reads from
  # $OMARCHY_PATH/default/limine/{limine,default}.conf). omarchy-settings
  # explicitly excludes default/limine when shipping its default/** tree so
  # this package owns these paths.
  install -Dm644 default/limine/limine.conf \
    "$pkgdir/usr/share/omarchy/default/limine/limine.conf"

  # default.conf is a template: install/login/limine-snapper.sh copies it to
  # /etc/default/limine and seds @@CMDLINE@@ to the live boot cmdline.
  install -Dm644 default/limine/default.conf \
    "$pkgdir/usr/share/omarchy/default/limine/default.conf"

  # Snapper config template used by the install-time `snapper create-config`.
  install -Dm644 default/snapper/root \
    "$pkgdir/etc/snapper/config-templates/omarchy"
}
