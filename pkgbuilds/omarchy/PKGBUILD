# Source: GitHub tag tarball by default; set OMARCHY_SRC=/path/to/checkout to
# build from a local source tree instead (mirrors omarchy-zsh/omarchy-fish DX).
# Until v4.0.0.alpha is tagged on basecamp/omarchy, sha256sums=('SKIP').
if [[ -n "${OMARCHY_SRC:-}" ]]; then
  source=()
  sha256sums=()
else
  source=("omarchy-${pkgver}.tar.gz::https://github.com/basecamp/omarchy/archive/refs/tags/v${pkgver}.tar.gz")
  sha256sums=('SKIP')
fi

prepare() {
  if [[ -n "${OMARCHY_SRC:-}" ]]; then
    rm -rf "$srcdir/omarchy-${pkgver}"
    mkdir -p "$srcdir/omarchy-${pkgver}"
    cp -a "${OMARCHY_SRC}/." "$srcdir/omarchy-${pkgver}/"
  fi
}

package() {
  cd "$srcdir/omarchy-${pkgver}"

  # Runtime binaries — ship everything in bin/ except the explicit exclusions:
  # - dev/debug helpers (shipped by omarchy-dev-tools and omarchy-settings)
  # - the dropped refactor-poc installer wrappers (never ship)
  install -d "$pkgdir/usr/bin"
  for bin in bin/*; do
    [[ -f $bin ]] || continue
    local base
    base=$(basename "$bin")
    case "$base" in
      omarchy-dev-*|omarchy-debug|omarchy-debug-idle|omarchy-upload-log|omarchy-install|omarchy-disk-config|omarchy-install-final-configurations.sh)
        continue
        ;;
    esac
    install -Dm755 "$bin" "$pkgdir/usr/bin/$base"
  done

  install -d "$pkgdir/usr/share/omarchy"

  # Theme bundles for theme switching.
  cp -a themes "$pkgdir/usr/share/omarchy/"

  # Versioned migrations runner reads from this tree.
  cp -a migrations "$pkgdir/usr/share/omarchy/"

  # Quickshell desktop shell tree.
  cp -a shell "$pkgdir/usr/share/omarchy/"

  # Runtime version file.
  install -Dm644 version "$pkgdir/usr/share/omarchy/version"
}
