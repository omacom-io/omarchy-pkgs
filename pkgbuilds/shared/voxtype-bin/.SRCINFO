pkgbase = voxtype-bin
	pkgdesc = Push-to-talk voice-to-text for Linux (pre-built binaries)
	pkgver = 0.6.5
	pkgrel = 1
	url = https://voxtype.io
	install = voxtype-bin.install
	arch = x86_64
	license = MIT
	depends = alsa-lib
	depends = curl
	depends = gcc-libs
	depends = glibc
	optdepends = wtype: keyboard simulation for Wayland (recommended, best CJK support)
	optdepends = dotool: keyboard simulation with layout support (KDE/GNOME compatible)
	optdepends = ydotool: keyboard simulation fallback (X11/TTY support)
	optdepends = wl-clipboard: clipboard support
	optdepends = libnotify: desktop notifications
	optdepends = pipewire: audio server (recommended)
	optdepends = pipewire-alsa: ALSA compatibility for PipeWire (required if using PipeWire)
	optdepends = pulseaudio: audio server (alternative to PipeWire)
	optdepends = vulkan-icd-loader: GPU acceleration via Vulkan for Whisper (enable with: voxtype setup gpu --enable)
	optdepends = cuda: GPU acceleration via CUDA for ONNX engines (NVIDIA GPUs)
	optdepends = rocm-hip-runtime: GPU acceleration via ROCm for ONNX engines (AMD GPUs)
	optdepends = ollama: local AI summarization for meeting mode
	provides = voxtype
	conflicts = voxtype
	backup = etc/voxtype/config.toml
	source = voxtype-0.6.5-avx2::https://github.com/peteonrails/voxtype/releases/download/v0.6.5/voxtype-0.6.5-linux-x86_64-avx2
	source = voxtype-0.6.5-avx512::https://github.com/peteonrails/voxtype/releases/download/v0.6.5/voxtype-0.6.5-linux-x86_64-avx512
	source = voxtype-0.6.5-vulkan::https://github.com/peteonrails/voxtype/releases/download/v0.6.5/voxtype-0.6.5-linux-x86_64-vulkan
	source = voxtype-0.6.5-onnx-avx2::https://github.com/peteonrails/voxtype/releases/download/v0.6.5/voxtype-0.6.5-linux-x86_64-onnx-avx2
	source = voxtype-0.6.5-onnx-avx512::https://github.com/peteonrails/voxtype/releases/download/v0.6.5/voxtype-0.6.5-linux-x86_64-onnx-avx512
	source = voxtype-0.6.5-onnx-cuda::https://github.com/peteonrails/voxtype/releases/download/v0.6.5/voxtype-0.6.5-linux-x86_64-onnx-cuda
	source = voxtype-0.6.5-onnx-rocm::https://github.com/peteonrails/voxtype/releases/download/v0.6.5/voxtype-0.6.5-linux-x86_64-onnx-rocm
